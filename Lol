local function buildRelicList()
    relicLabelToUUID = {} relicLabels = {}
    local ok, relics = pcall(function() return shared.Replica.Data.Relics end)
    if not ok or not relics then relicLabels = {"No Relics"} return end
    local entries = {}
    for uuid, data in pairs(relics) do
        local label = (data.Name or uuid)
        if data.Equipped then label = label .. " [E]" end
        if data.Locked then label = label .. " [L]" end
        label = label .. " Lv" .. (data.Level or 1)
        table.insert(entries, { label = label, uuid = uuid, name = data.Name or uuid })
    end
    table.sort(entries, function(a, b) return a.name < b.name end)
    for _, v in ipairs(entries) do
        relicLabelToUUID[v.label] = v.uuid
        table.insert(relicLabels, v.label)
    end
    if #relicLabels == 0 then relicLabels = {"No Relics"} end
end

