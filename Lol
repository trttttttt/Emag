    local saveTh = New("Frame",{Parent=saveTr,Size=UDim2.new(0,16,0,16),Position=saveOn and UDim2.new(1,-19,0.5,0) or UDim2.new(0,3,0.5,0),AnchorPoint=Vector2.new(0,0.5),BackgroundColor3=Theme.White,BorderSizePixel=0,ZIndex=9},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
    New("TextButton",{Parent=SaveCard,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=10}).MouseButton1Click:Connect(function()
        saveOn = not saveOn
        Config._enabled = saveOn
        Tween(saveTr,{BackgroundColor3=saveOn and Theme.ToggleOn or Theme.ToggleOff},0.2)
        Tween(saveTh,{Position=saveOn and UDim2.new(1,-19,0.5,0) or UDim2.new(0,3,0.5,0)},0.2)
        Notify(saveOn and "✓ Config Save ON" or "Config Save OFF","",1)
    end)

    -- Save Now + Reset buttons
    local BtnCard2 = SCard(SettingsPage,50)
    New("TextLabel",{Parent=BtnCard2,Text="Manual Control",Font=Enum.Font.GothamSemibold,TextSize=13,TextColor3=Theme.Text,TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,Size=UDim2.new(0.5,0,1,0),Position=UDim2.new(0,14,0,0),ZIndex=8})
    local BtnHolder = New("Frame",{Parent=BtnCard2,Size=UDim2.new(0,168,0,30),Position=UDim2.new(1,-178,0.5,0),AnchorPoint=Vector2.new(0,0.5),BackgroundTransparency=1,ZIndex=8},{New("UIListLayout",{Padding=UDim.new(0,6),FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center})})

    local SaveNowBtn = New("TextButton",{Parent=BtnHolder,Text="SAVE NOW",Font=Enum.Font.GothamBold,TextSize=10,TextColor3=Theme.White,BackgroundColor3=Theme.Accent,BorderSizePixel=0,Size=UDim2.new(0,80,1,0),ZIndex=9},{New("UICorner",{CornerRadius=UDim.new(0,7)})})
    TrackAccent(SaveNowBtn,"BackgroundColor3")
    SaveNowBtn.MouseButton1Click:Connect(function()
        Config:Save()
        Tween(SaveNowBtn,{BackgroundColor3=Theme.Success},0.15)
        task.delay(0.8,function() Tween(SaveNowBtn,{BackgroundColor3=Theme.Accent},0.3) end)
        Notify("✓ Saved","Config disimpan ke "..cfgFile,2)
    end)

    local ResetBtn = New("TextButton",{Parent=BtnHolder,Text="RESET",Font=Enum.Font.GothamBold,TextSize=10,TextColor3=Theme.White,BackgroundColor3=Color3.fromRGB(80,25,25),BorderSizePixel=0,Size=UDim2.new(0,68,1,0),ZIndex=9},{New("UICorner",{CornerRadius=UDim.new(0,7)})})
    ResetBtn.MouseButton1Click:Connect(function()
        Config:Reset()
        Tween(ResetBtn,{BackgroundColor3=Theme.Danger},0.15)
        task.delay(0.8,function() Tween(ResetBtn,{BackgroundColor3=Color3.fromRGB(80,25,25)},0.3) end)
        Notify("Config Reset","Semua settings dikembalikan ke default.",3)
    end)

    -- ─── ICON ID ───
    SHdr(SettingsPage,"Icon")
    local ICard = SCard(SettingsPage,76)
    SRow(ICard,"Button Icon ID","Masukkan Roblox Asset ID")
    local IInput = New("TextBox",{Parent=ICard,Text="",PlaceholderText="rbxassetid://123456789",Font=Enum.Font.GothamMono,TextSize=12,TextColor3=Theme.Text,PlaceholderColor3=Theme.SubText,BackgroundColor3=Theme.Bg,BorderSizePixel=0,Size=UDim2.new(0.68,0,0,26),Position=UDim2.new(0,14,0,44),ClearTextOnFocus=false,ZIndex=8},{New("UICorner",{CornerRadius=UDim.new(0,6)}),New("UIPadding",{PaddingLeft=UDim.new(0,8)}),New("UIStroke",{Color=Theme.Border,Thickness=1,Transparency=0.4})})
    local IApply = New("TextButton",{Parent=ICard,Text="APPLY",Font=Enum.Font.GothamBold,TextSize=10,TextColor3=Theme.White,BackgroundColor3=Theme.Accent,BorderSizePixel=0,Size=UDim2.new(0.24,0,0,26),Position=UDim2.new(0.74,0,0,44),ZIndex=8},{New("UICorner",{CornerRadius=UDim.new(0,6)})})
    TrackAccent(IApply,"BackgroundColor3")
    IApply.MouseButton1Click:Connect(function()
        SetIcon(DragBtnIcon,IInput.Text); SetIcon(WinIcon,IInput.Text)
        Config:Set("__icon",IInput.Text)
        Notify("✓ Icon Updated","Button icon ditukar!",2)
    end)
    -- Restore saved icon
    local savedIcon = Config:Get("__icon","")
    if savedIcon ~= "" then
        IInput.Text = savedIcon
        SetIcon(DragBtnIcon,savedIcon); SetIcon(WinIcon,savedIcon)
    end

    -- ════════════════════════════
    --    SETTINGS SIDEBAR BTN
    -- ════════════════════════════
    local SettingsBtn = New("TextButton",{Parent=SidebarBottom,Size=UDim2.new(1,-12,0,38),Position=UDim2.new(0,6,0,7),BackgroundColor3=Theme.Element,BackgroundTransparency=1,BorderSizePixel=0,Text="",ZIndex=8},{New("UICorner",{CornerRadius=UDim.new(0,9)})})
    New("TextLabel",{Parent=SettingsBtn,Text="⚙  Settings",Font=Enum.Font.GothamSemibold,TextSize=13,TextColor3=Theme.SubText,TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,Size=UDim2.new(1,-10,1,0),Position=UDim2.new(0,10,0,0),ZIndex=9})

    -- ════════════════════════════
    --    WINDOW OBJECT
    -- ════════════════════════════
    local Window   = {}
    Window._Tabs   = {}
    Window._Config = Config

    function Window:CreateTab(tabName, tabIcon)
        tabName = tabName or "Tab"
        local Tab        = {}
        Tab._Name        = tabName
        Tab._SubTabs     = {}
        Tab._Expanded    = false

        local TabCon = New("Frame",{Parent=Sidebar,Size=UDim2.new(1,0,0,34),BackgroundTransparency=1,AutomaticSize=Enum.AutomaticSize.Y,LayoutOrder=#Window._Tabs+1},{New("UIListLayout",{Padding=UDim.new(0,0),SortOrder=Enum.SortOrder.LayoutOrder})})
        local TabBtn = New("TextButton",{Parent=TabCon,Size=UDim2.new(1,0,0,34),BackgroundColor3=Theme.Element,BackgroundTransparency=1,BorderSizePixel=0,Text="",ZIndex=7,LayoutOrder=0},{New("UICorner",{CornerRadius=UDim.new(0,9)})})
        local TabIcon= New("ImageLabel",{Parent=TabBtn,Size=UDim2.new(0,20,0,20),Position=UDim2.new(0,8,0.5,0),AnchorPoint=Vector2.new(0,0.5),BackgroundTransparency=1,Image="rbxassetid://7059346373",ImageColor3=Theme.SubText,ZIndex=8})
        SetIcon(TabIcon,tabIcon)
        local TabLbl = New("TextLabel",{Parent=TabBtn,Text=tabName,Font=Enum.Font.GothamSemibold,TextSize=13,TextColor3=Theme.SubText,TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,Size=UDim2.new(1,-60,1,0),Position=UDim2.new(0,34,0,0),ZIndex=8})
        local ArrLbl = New("TextLabel",{Parent=TabBtn,Text="▶",Font=Enum.Font.GothamBold,TextSize=9,TextColor3=Theme.SubText,BackgroundTransparency=1,Size=UDim2.new(0,20,1,0),Position=UDim2.new(1,-22,0,0),ZIndex=8})
        local SubList= New("Frame",{Parent=TabCon,Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,ClipsDescendants=true,LayoutOrder=1},{New("UIListLayout",{Padding=UDim.new(0,1),SortOrder=Enum.SortOrder.LayoutOrder})})

        local Page = New("ScrollingFrame",{Parent=PageContainer,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=3,ScrollBarImageColor3=Theme.Accent,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Visible=false,ZIndex=6},{New("UIListLayout",{Padding=UDim.new(0,8),SortOrder=Enum.SortOrder.LayoutOrder}),New("UIPadding",{PaddingTop=UDim.new(0,16),PaddingLeft=UDim.new(0,16),PaddingRight=UDim.new(0,16),PaddingBottom=UDim.new(0,16)})})
        TrackAccent(Page,"ScrollBarImageColor3")

        Tab._Page=Page; Tab._SubList=SubList; Tab._Btn=TabBtn; Tab._Lbl=TabLbl; Tab._Icn=TabIcon

        local function SelTab()
            for _,t in pairs(Window._Tabs) do
                if t._Page then t._Page.Visible=false end
                Tween(t._Btn,{BackgroundTransparency=1},0.18)
                if t._Lbl then Tween(t._Lbl,{TextColor3=Theme.SubText},0.18) end
                if t._Icn then Tween(t._Icn,{ImageColor3=Theme.SubText},0.18) end
            end
            SettingsPage.Visible=false
            Tween(SettingsBtn,{BackgroundTransparency=1},0.18)
            Page.Visible=true
            Tween(TabBtn,{BackgroundTransparency=0},0.18)
            Tween(TabLbl,{TextColor3=Theme.Text},0.18)
            Tween(TabIcon,{ImageColor3=Theme.Accent},0.18)
            TrackAccent(TabIcon,"ImageColor3")
            Window._ActiveTab=Tab
        end

        TabBtn.MouseButton1Click:Connect(function()
            Tab._Expanded=not Tab._Expanded
            Tween(ArrLbl,{Rotation=Tab._Expanded and 90 or 0},0.2)
            Tween(SubList,{Size=UDim2.new(1,0,0,Tab._Expanded and #Tab._SubTabs*29 or 0)},0.25)
            SelTab()
        end)
        TabBtn.MouseEnter:Connect(function() if Window._ActiveTab~=Tab then Tween(TabBtn,{BackgroundTransparency=0.6},0.18) end end)
        TabBtn.MouseLeave:Connect(function() if Window._ActiveTab~=Tab then Tween(TabBtn,{BackgroundTransparency=1},0.18) end end)
        table.insert(Window._Tabs,Tab)
        if #Window._Tabs==1 then SelTab(); Tab._Expanded=true; ArrLbl.Rotation=90 end

        -- ── Element creators (all auto-save via Config) ──
        function Tab:CreateToggle(cfg)   return MakeToggle(Page,cfg)   end
        function Tab:CreateSlider(cfg)   return MakeSlider(Page,cfg)   end
        function Tab:CreateButton(cfg)   return MakeButton(Page,cfg)   end
        function Tab:CreateDropdown(cfg) return MakeDropdown(Page,cfg) end
        function Tab:CreateInput(cfg)    return MakeInput(Page,cfg)    end
        function Tab:CreateSection(n)    return MakeSection(Page,n)    end
        function Tab:CreateLabel(t)      return MakeLabel(Page,t)      end
        function Tab:SetIcon(id)         SetIcon(TabIcon,id)           end

        -- ── CreateSubTab ──
        function Tab:CreateSubTab(sName, sIcon)
            local ST = {}
            local SPage = New("ScrollingFrame",{Parent=PageContainer,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=3,ScrollBarImageColor3=Theme.Accent,CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,Visible=false,ZIndex=6},{New("UIListLayout",{Padding=UDim.new(0,8),SortOrder=Enum.SortOrder.LayoutOrder}),New("UIPadding",{PaddingTop=UDim.new(0,16),PaddingLeft=UDim.new(0,16),PaddingRight=UDim.new(0,16),PaddingBottom=UDim.new(0,16)})})
            TrackAccent(SPage,"ScrollBarImageColor3")
            local SBtn = New("TextButton",{Parent=SubList,Size=UDim2.new(1,0,0,28),BackgroundColor3=Theme.Element,BackgroundTransparency=1,BorderSizePixel=0,Text="",ZIndex=8,LayoutOrder=#Tab._SubTabs+1},{New("UICorner",{CornerRadius=UDim.new(0,8)})})
            local SDot = New("Frame",{Parent=SBtn,Size=UDim2.new(0,5,0,5),Position=UDim2.new(0,18,0.5,0),AnchorPoint=Vector2.new(0,0.5),BackgroundColor3=Theme.SubText,BorderSizePixel=0,ZIndex=9},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
            if sIcon and sIcon~="" then local si=New("ImageLabel",{Parent=SBtn,Size=UDim2.new(0,14,0,14),Position=UDim2.new(0,28,0.5,0),AnchorPoint=Vector2.new(0,0.5),BackgroundTransparency=1,ZIndex=9}); SetIcon(si,sIcon) end
            local SLbl = New("TextLabel",{Parent=SBtn,Text=sName or "Sub",Font=Enum.Font.Gotham,TextSize=12,TextColor3=Theme.SubText,TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,Size=UDim2.new(1,-48,1,0),Position=UDim2.new(0,(sIcon and sIcon~="") and 48 or 30,0,0),ZIndex=9})

            local function SelSub()
                for _,t2 in pairs(Window._Tabs) do
                    if t2._Page then t2._Page.Visible=false end
                    for _,s2 in pairs(t2._SubTabs) do
                        if s2._Page then s2._Page.Visible=false end
                        if s2._Lbl then Tween(s2._Lbl,{TextColor3=Theme.SubText},0.15) end
                        if s2._Dot then Tween(s2._Dot,{BackgroundColor3=Theme.SubText},0.15) end
                        Tween(s2._Btn,{BackgroundTransparency=1},0.15)
                    end
                end
                SettingsPage.Visible=false
                SPage.Visible=true
                Tween(SLbl,{TextColor3=Theme.Accent},0.15)
                Tween(SDot,{BackgroundColor3=Theme.Accent},0.15)
                TrackAccent(SDot,"BackgroundColor3")
                Tween(SBtn,{BackgroundTransparency=0.7},0.15)
            end
            SBtn.MouseButton1Click:Connect(SelSub)
            SBtn.MouseEnter:Connect(function() Tween(SBtn,{BackgroundTransparency=0.8},0.12); Tween(SLbl,{TextColor3=Theme.Text},0.12) end)
            SBtn.MouseLeave:Connect(function() Tween(SBtn,{BackgroundTransparency=1},0.12); if not SPage.Visible then Tween(SLbl,{TextColor3=Theme.SubText},0.12) end end)

            ST._Page=SPage; ST._Lbl=SLbl; ST._Dot=SDot; ST._Btn=SBtn
            table.insert(Tab._SubTabs,ST)
            if Tab._Expanded then Tween(SubList,{Size=UDim2.new(1,0,0,#Tab._SubTabs*29)},0.2) end

            function ST:CreateToggle(cfg)   return MakeToggle(SPage,cfg)   end
            function ST:CreateSlider(cfg)   return MakeSlider(SPage,cfg)   end
            function ST:CreateButton(cfg)   return MakeButton(SPage,cfg)   end
            function ST:CreateDropdown(cfg) return MakeDropdown(SPage,cfg) end
            function ST:CreateInput(cfg)    return MakeInput(SPage,cfg)    end
            function ST:CreateSection(n)    return MakeSection(SPage,n)    end
            function ST:CreateLabel(t)      return MakeLabel(SPage,t)      end
            return ST
        end

        return Tab
    end

    -- Settings btn wiring
    SettingsBtn.MouseButton1Click:Connect(function()
        for _,t in pairs(Window._Tabs) do
            if t._Page then t._Page.Visible=false end
            Tween(t._Btn,{BackgroundTransparency=1},0.18)
            if t._Lbl then Tween(t._Lbl,{TextColor3=Theme.SubText},0.18) end
            if t._Icn then Tween(t._Icn,{ImageColor3=Theme.SubText},0.18) end
        end
        SettingsPage.Visible=true
        Tween(SettingsBtn,{BackgroundTransparency=0},0.18)
    end)
    SettingsBtn.MouseEnter:Connect(function() Tween(SettingsBtn,{BackgroundTransparency=0.6},0.15) end)
    SettingsBtn.MouseLeave:Connect(function() if not SettingsPage.Visible then Tween(SettingsBtn,{BackgroundTransparency=1},0.15) end end)

    function Window:Notify(t,d,dur) Notify(t,d,dur) end
    function Window:SetIcon(id) SetIcon(DragBtnIcon,id); SetIcon(WinIcon,id) end
    function Window:SaveConfig() Config:Save() end
    function Window:ResetConfig() Config:Reset() end
    function Window:Destroy() ScreenGui:Destroy() end

    return Window
end

return NexUI
