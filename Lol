local function ClearESP() for _,h in pairs(espH) do pcall(function() h:Destroy() end) end; espH={} end
local function BuildESP()
    ClearESP()
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        pcall(function()
            local c=p.Character; if not c then return end
            local h=Instance.new("Highlight",c)
            h.FillColor=S.ESPColor; h.OutlineColor=Color3.new(1,1,1)
            h.FillTransparency=0.5; h.OutlineTransparency=0
            espH[p.Name]=h
        end)
    end
end

SubESP:CreateToggle({Name="Enable ESP",Flag="ESPOn",CurrentValue=false,
    Description="Highlight all players through walls",
    Callback=function(v) S.ESPOn=v; if v then BuildESP() else ClearESP() end end})
SubESP:CreateSlider({Name="Fill Transparency",Range={0,9},Increment=1,CurrentValue=5,Suffix="/10",Flag="ESPFillT",Callback=function(v)
    local t=v/10
    for _,h in pairs(espH) do h.FillTransparency=t end
end})
SubESP:CreateToggle({Name="Show Outline",Flag="ESPOutline",CurrentValue=true,Callback=function(v)
    for _,h in pairs(espH) do h.OutlineTransparency=v and 0 or 1 end
end})
SubESP:CreateSection("Colors")
SubESP:CreateColorPicker({Name="Fill Color",Flag="ESPColor",Color=Color3.fromRGB(255,0,80),Callback=function(c)
    S.ESPColor=c; for _,h in pairs(espH) do h.FillColor=c end
end})
SubESP:CreateButton({Name="Refresh ESP",Icon="refresh",Callback=function()
    if S.ESPOn then BuildESP(); Notif("ESP","Refreshed all highlights.","success") end
end})
C(Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function() task.wait(1); if S.ESPOn then BuildESP() end end)
end))
C(LP.CharacterAdded:Connect(function() task.wait(1); if S.ESPOn then BuildESP() end end))

