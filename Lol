    local ok, weapons = pcall(function() return shared.Replica.Data.Weapons end)
    if not ok or not weapons then wpnLabels = {"No Weapons"} return end
    local entries = {}
    for uuid, data in pairs(weapons) do
        local label = (data.Name or uuid)
        if data.Equipped then label = label .. " [E]" end
        if data.Locked then label = label .. " [L]" end
        table.insert(entries, { label = label, uuid = uuid, name = data.Name or uuid })
