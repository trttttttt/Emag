local function getMobNames()
    local result = {}
    local seen = {}
    local folder = workspace:FindFirstChild("Mobs")
    if not folder then return {"No Mobs Found"} end
    for _, mob in ipairs(folder:GetChildren()) do
        local ok, name = pcall(function()
            return mob.HumanoidRootPart.EnemyOverhead.Enemy.Text
        end)
        if ok and name and name ~= "" and not seen[name] then
            seen[name] = true
            table.insert(result, name)
        end
    end
    if #result == 0 then return {"No Mobs Found"} end
    return result
end

-- NEAREST MOB: cari mob dari selectedMobs yang paling dekat dengan player
local function findNearestLiveMob()
    local hrp = getHRP()
    if not hrp then return nil, nil end
    local folder = workspace:FindFirstChild("Mobs")
    if not folder then return nil, nil end

    local nearestMob = nil
    local nearestHum = nil
    local nearestDist = math.huge

    -- Buat lookup table untuk selected mob names
    local selectedSet = {}
    for _, name in ipairs(selectedMobs) do
        selectedSet[name] = true
    end

    for _, mob in ipairs(folder:GetChildren()) do
        local ok, text = pcall(function()
            return mob.HumanoidRootPart.EnemyOverhead.Enemy.Text
        end)
        if ok and text and selectedSet[text] then
            local hum = mob:FindFirstChildOfClass("Humanoid")
            local mobHRP = mob:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and mobHRP then
                local dist = (hrp.Position - mobHRP.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestMob = mob
                    nearestHum = hum
                end
            end
        end
    end

    return nearestMob, nearestHum
end

local function waitForDeath(mob, hum)
    local dead = false
    local conn1, conn2, conn3
    local function markDead() dead = true end
    conn1 = hum.Died:Connect(markDead)
    conn2 = hum:GetPropertyChangedSignal("Health"):Connect(function()
        if hum.Health <= 0 then markDead() end
    end)
    conn3 = mob.AncestryChanged:Connect(function(_, p)
        if not p then markDead() end
    end)
    while not dead do
        task.wait(0.05)
        if not farmActive or #selectedMobs == 0 then break end
    end
    pcall(function() conn1:Disconnect() end)
    pcall(function() conn2:Disconnect() end)
    pcall(function() conn3:Disconnect() end)
end

-- Satu cycle mob farm - return true kalau berjaya kill
local function doMobFarmCycle()
    if #selectedMobs == 0 then task.wait(0.5) return false end
    local mob, hum = findNearestLiveMob()
    if mob and hum then
        teleportToMob(mob)
        waitForDeath(mob, hum)
        task.wait(0.2)
        return true
    else
        task.wait(0.2)
        return false
    end
end

local function stopFarm()
    farmActive = false
    if farmThread then task.cancel(farmThread) farmThread = nil end
end

local function startFarm()
    if farmThread then task.cancel(farmThread) farmThread = nil end
    farmActive = true
    farmThread = task.spawn(function()
        while farmActive do
            doMobFarmCycle()
        end
    end)
end

