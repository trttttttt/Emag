end

local function parseNumber(val)
    local s = tostring(val):gsub(",", ""):lower()
    local num, suffix = s:match("^([%d%.]+)([kmb]?)$")
    if not num then return 0 end
    num = tonumber(num) or 0
    if suffix == "k" then num = num * 1000
    elseif suffix == "m" then num = num * 1000000
    elseif suffix == "b" then num = num * 1000000000 end
    return math.floor(num)
end

local function getPlayerGems()
    local ls = lp:FindFirstChild("leaderstats")
    if ls then
        local gems = ls:FindFirstChild("Gems")
        if gems then return parseNumber(gems.Value) end
    end
    return 0
end

local function getEggCost(starName)
    local ok, val = pcall(function()
        return workspace.Stars[starName].Star.Primary.StarGui.Gems.Amount.Text
    end)
    if ok and val then return parseNumber(val) end
    return 0
end

local function teleportToStar(starName)
    local hrp = getHRP()
    local ok, cube = pcall(function() return workspace.Stars[starName].Cube end)
    if hrp and ok and cube then hrp.CFrame = CFrame.new(cube.Position) * CFrame.new(5, 0, 0) end
end

local function isNearStar(starName)
    local hrp = getHRP()
    local ok, cube = pcall(function() return workspace.Stars[starName].Cube end)
    if hrp and ok and cube then return (hrp.Position - cube.Position).Magnitude <= 10 end
    return false
end

local function teleportToMob(mob)
