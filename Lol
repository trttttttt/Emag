-- ─── Connections table ──────────────────────────────────────
local Conns = {}
local function AddConn(c) table.insert(Conns, c) end
local function ClearConns()
    for _, c in ipairs(Conns) do pcall(function() c:Disconnect() end) end
    Conns = {}
end

