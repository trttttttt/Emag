local QuestTab = Window:CreateTab("Quest", nil)
local questFarmActive = false
local questFarmThread = nil
local currentQuestPart = 1
local selectedStartPart = 1
local selectedWorld = "Leaf Village"
local QUEST_WORLDS = {"Leaf Village", "Nomek", "Egg City", "Lost City", "Slayers Hideout", "Jujutsu School"}

local function makeQuestId(world, part)
    return world .. "_Main_Part_" .. tostring(part)
end

local function parseAmount(text)
    local cur, req = text:match("(%d+)%s*/%s*(%d+)")
    return tonumber(cur) or 0, tonumber(req) or 0
end

local function getQuestDefeatList(part)
    local questId = makeQuestId(selectedWorld, part)
    local ok, defeatList = pcall(function()
        return lp.PlayerGui.Main.Canvas["Quests Manager"].Main.List[questId].Defeat.List
    end)
    return ok and defeatList or nil
end

local function acceptQuestPart(part)
    pcall(function() getService("QuestService").RF.AcceptQuest:InvokeServer(makeQuestId(selectedWorld, part)) end)
end

local function completeQuestPart(part)
    pcall(function() getService("QuestService").RF.CompleteQuest:InvokeServer(makeQuestId(selectedWorld, part)) end)
end

local function isQuestAccepted(part) return getQuestDefeatList(part) ~= nil end

local function isQuestComplete(part)
    local defeatList = getQuestDefeatList(part)
    if not defeatList then return false end
    local found = false
    for _, entry in pairs(defeatList:GetChildren()) do
        if entry.Name == "Template" then continue end
        local ok, amtText = pcall(function() return entry.Button.Amount.Text end)
        if ok and amtText then
            found = true
            local cur, req = parseAmount(amtText)
            if cur < req then return false end
        end
    end
    return found
end

local function getCurrentQuestTargets(part)
    local defeatList = getQuestDefeatList(part)
    if not defeatList then return {} end
    local targets = {}
    for _, entry in pairs(defeatList:GetChildren()) do
        if entry.Name == "Template" then continue end
        local okA, amtText = pcall(function() return entry.Button.Amount.Text end)
        if okA and amtText then
            local cur, req = parseAmount(amtText)
            if cur < req then targets[entry.Name] = {current = cur, required = req} end
        end
    end
    return targets
end

local function findQuestMob(targets)
    local hrp = getHRP()
    if not hrp then return nil, nil end
    local folder = workspace:FindFirstChild("Mobs")
    if not folder then return nil, nil end
    local nearestMob, nearestHum, nearestDist = nil, nil, math.huge
    for _, mob in ipairs(folder:GetChildren()) do
        local ok, text = pcall(function() return mob.HumanoidRootPart.EnemyOverhead.Enemy.Text end)
        if ok and text then
            local stripped = text:gsub("^Defeat%s+", "")
            if targets[stripped] or targets[text] then
                local hum = mob:FindFirstChildOfClass("Humanoid")
                local mobHRP = mob:FindFirstChild("HumanoidRootPart")
                if hum and hum.Health > 0 and mobHRP then
                    local dist = (hrp.Position - mobHRP.Position).Magnitude
                    if dist < nearestDist then nearestDist = dist nearestMob = mob nearestHum = hum end
                end
            end
        end
    end
    return nearestMob, nearestHum
end

local function stopQuestFarm()
    questFarmActive = false
    if questFarmThread then task.cancel(questFarmThread) questFarmThread = nil end
end

local function startQuestFarm()
    stopQuestFarm()
    questFarmActive = true
    currentQuestPart = selectedStartPart
    questFarmThread = task.spawn(function()
        Rayfield:Notify({ Title = "Quest Farm Start", Content = "World: " .. selectedWorld .. " | Part " .. selectedStartPart .. " to 7", Duration = 4, Image = 4483362458 })
        while questFarmActive and currentQuestPart <= 7 do
            local part = currentQuestPart
            if isQuestComplete(part) then
                currentQuestPart = currentQuestPart + 1
                task.wait(0.3)
                continue
            end
            acceptQuestPart(part)
            local waited = 0
            while not isQuestAccepted(part) and waited < 5 do task.wait(0.3) waited = waited + 0.3 end
            Rayfield:Notify({ Title = "Quest Accepted: Part " .. part, Content = selectedWorld, Duration = 3, Image = 4483362458 })
            local killCount = 0
            while questFarmActive and currentQuestPart == part do
                if isQuestComplete(part) then
                    completeQuestPart(part)
                    task.wait(0.5)
                    Rayfield:Notify({ Title = "Part " .. part .. " COMPLETE!", Content = "Killed: " .. killCount, Duration = 5, Image = 4483362458 })
                    currentQuestPart = currentQuestPart + 1
                    break
                end
                local targets = getCurrentQuestTargets(part)
                local count = 0
                for _ in pairs(targets) do count = count + 1 end
                if count == 0 then task.wait(0.3) continue end
                local mob, hum = findQuestMob(targets)
                if mob and hum then
                    teleportToMob(mob)
                    spamClickKill(mob, hum, function() return questFarmActive end)
                    killCount = killCount + 1
                    task.wait(0.1)
                else
                    task.wait(3)
                end
            end
        end
        if currentQuestPart > 7 then
            Rayfield:Notify({ Title = "Quest Farm Done!", Content = selectedWorld .. " Part 1-7 complete!", Duration = 7, Image = 4483362458 })
            questFarmActive = false
        end
    end)
end

