local function getProgressFromServer(npcName)
    local function check(qd)
        if qd and qd:FindFirstChild("NpcName") and qd.NpcName.Value==npcName then
            if qd:FindFirstChild("Progress") and qd:FindFirstChild("ProgressEnd") then
                return qd.Progress.Value, qd.ProgressEnd.Value
            end
        end
    end
    local p, e = check(Player:FindFirstChild("QuestData")); if p then return p, e end
    return check(Player:FindFirstChild("SecondQuestData"))
end

-- Detect what quest is currently active on the player (any type)
local function detectActiveQuest()
    for _, qdName in ipairs({"QuestData","SecondQuestData"}) do
        local qd = Player:FindFirstChild(qdName)
        if qd and qd:FindFirstChild("NpcName") and qd:FindFirstChild("Progress") and qd:FindFirstChild("ProgressEnd") then
            local npc = qd.NpcName.Value
            local info = QUEST_DATA[npc]
            if info then
                return npc, info, qd.Progress.Value, qd.ProgressEnd.Value
            end
        end
    end
    return nil
end

local function acceptQuest(npcName)
    pcall(function() ReplicatedStorage.RemoteFunctions.Quest:InvokeServer(npcName, true) end)
    task.wait(0.5)
end

local function warnPathQuest(questName)
    local info = QUEST_DATA[questName]
    if info and info.Path then
        Rayfield:Notify({
            Title   = "Quest Warning",
            Content = "Warning: This quest is for the '"..info.Path.."' path only!",
            Duration = 8, Image = 4483362458,
        })
    end
end

-- Quest Harvesting — same logic as doOneHerb
local function farmQuestHarvesting(npcName, target, lbl)
    setNoclip(true)
    while harvestQuestActive do
        local prog, pEnd = getProgressFromServer(npcName)
        if not prog then break end
        lbl:Set("Progress: "..prog.." / "..pEnd)
        if prog >= pEnd then break end
        local folder = getHerbFolder(target)
        if not folder then task.wait(3); continue end
        local herb = findRandomHerb(folder, 5, nil)
        if not herb or not herb.Parent then task.wait(2); continue end
        local zone = herb:FindFirstChild("HerbZone", true); if not zone then task.wait(0.5); continue end
        local targetCF = getCF(zone); if not targetCF then task.wait(0.2); continue end
        local reached = flyTo(targetCF.Position, function() return harvestQuestActive end)
        if not harvestQuestActive then break end
        if not reached then task.wait(0.2); continue end
        local attempt = 0
        while not isPlayerInZone(zone) and attempt < 10 and harvestQuestActive do
            attempt += 1
            local zCF = getCF(zone)
            if zCF then HRP.CFrame = CFrame.new(zCF.Position); HRP.AssemblyLinearVelocity = Vector3.zero end
            task.wait(0.05)
        end
        if not isPlayerInZone(zone) then continue end
        task.wait(0.3)
        if not isPlayerInZone(zone) or not harvestQuestActive then continue end
        pcall(function() ReplicatedStorage.RemoteEvents.Harvest:FireServer() end)
        waitForHarvestComplete(function() return harvestQuestActive end)
        if not harvestQuestActive then break end
    end
end

