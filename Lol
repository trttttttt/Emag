-- Load Rayfield with retry loop (fixes Delta nil on inject)
local Rayfield
do
    local URLS = {
        'https://sirius.menu/rayfield',
        'https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua',
    }
    local function tryLoad()
        for _, url in ipairs(URLS) do
            local src
            local ok = pcall(function() src = game:HttpGet(url) end)
            if ok and src and src ~= "" then
                local result
                if pcall(function() result = loadstring(src)() end) and result then
                    return result
                end
            end
        end
    end
    for attempt = 1, 5 do
        Rayfield = tryLoad()
        if Rayfield then break end
        warn(string.format("[MELAYU-HUB] Rayfield failed (attempt %d/5), retrying in 2s...", attempt))
        task.wait(2)
    end
    if not Rayfield then
        warn("[MELAYU-HUB] Failed to load Rayfield. Enable HTTP Requests in Delta settings.")
        return
    end
end

