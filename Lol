-- Generic quest runner — auto-detects active quest if none selected
local function runQuestLoop(activeFlag, setActive, selectedQuest, farmFunc, questType, lblNPC, lblTgt, lblProg)
    while activeFlag() do
        -- 1. Try to find an already-active quest on the player
        local detected, info, prog, pEnd = detectActiveQuest()

        -- Filter by type so harvesting loop doesn't grab slaying quest and vice versa
        if detected and info and info.Type ~= questType then
            detected = nil
        end

        -- 2. If nothing detected and user selected a quest, try to accept it
        if not detected and selectedQuest then
            acceptQuest(selectedQuest); task.wait(1)
            detected, info, prog, pEnd = detectActiveQuest()
            if detected and info.Type ~= questType then detected = nil end
            if not detected then
                Rayfield:Notify({Title="Quest", Content="Not eligible for: "..selectedQuest, Duration=5, Image=4483362458})
                task.wait(3); continue
            end
        end

        if not detected then task.wait(1); continue end

        -- Show info
        lblNPC:Set("NPC: "..detected)
        lblTgt:Set("Target: "..info.Target.." x"..info.Amount)
        lblProg:Set("Progress: "..prog.." / "..pEnd)

        -- Run the farm function
        farmFunc(detected, info.Target, lblProg)

        if not activeFlag() then break end

        -- Check if quest is done
        local p2 = getProgressFromServer(detected)
        if not p2 then
            lblTgt:Set("Quest complete!")
            if questLoopEnabled then
                task.wait(2); acceptQuest(detected); task.wait(1)
            else
                setActive(false); stopFlyNoclip(); break
            end
        end
        task.wait(1)
    end
    stopFlyNoclip()
end

