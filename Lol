local AccentObjects = {}
local function TrackAccent(obj, prop)
    table.insert(AccentObjects, {obj=obj, prop=prop})
end

local function ApplyColorTheme(preset)
    local p = ColorPresets[preset]
    if not p then return end
    Theme.Accent    = p.Accent
    Theme.AccentDim = p.AccentDim
    Theme.ToggleOn  = p.ToggleOn
    for _, e in ipairs(AccentObjects) do
        pcall(function() Tween(e.obj, {[e.prop]=p.Accent}, 0.3) end)
    end
end

