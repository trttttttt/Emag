local questStatusLabel = QuestTab:CreateLabel("World: Leaf Village | Part: 1")
task.spawn(function()
    while true do
        task.wait(0.5)
        if not questFarmActive then
            questStatusLabel:Set("World: " .. selectedWorld .. " | Start Part: " .. tostring(selectedStartPart))
            continue
        end
        local defeatList = getQuestDefeatList(currentQuestPart)
        if not defeatList then
            questStatusLabel:Set("Part " .. currentQuestPart .. ": Accepting quest...")
        else
            local parts, allDone, hasAny = {}, true, false
            for _, entry in pairs(defeatList:GetChildren()) do
                if entry.Name == "Template" then continue end
                local okA, a = pcall(function() return entry.Button.Amount.Text end)
                if okA and a then
                    hasAny = true
                    local cur, req = parseAmount(a)
                    if cur < req then allDone = false end
                    table.insert(parts, entry.Name .. ": " .. cur .. "/" .. req)
                end
            end
            if not hasAny then questStatusLabel:Set("Part " .. currentQuestPart .. ": Loading...")
            elseif allDone then questStatusLabel:Set("[DONE] Part " .. currentQuestPart .. " | " .. table.concat(parts, " | "))
            else questStatusLabel:Set("Part " .. currentQuestPart .. " | " .. table.concat(parts, " | ")) end
        end
    end
end)

