    return #result > 0 and result or {"No Mobs Found"}
end

local function startFarmThread()
    if farmThread then task.cancel(farmThread) farmThread = nil end
    farmThread = task.spawn(function()
        while farmActive do
            if #selectedMobs == 0 then task.wait(0.5) continue end
            local mob, hum = findNearestMob(selectedMobs)
            if mob and hum then
                teleportToMob(mob)
                spamClickKill(mob, hum, function() return farmActive and #selectedMobs > 0 and not eggActive end)
                task.wait(0.2)
            else task.wait(0.2) end
        end
    end)
end

local function stopFarm()
    farmActive = false
    if farmThread then task.cancel(farmThread) farmThread = nil end
end

