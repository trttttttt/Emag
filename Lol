-- Aimbot loop
C(RunService.RenderStepped:Connect(function(dt)
    local center=GetViewportCenter()

    -- Update FOV circle position
    if fovCircle then
        fovCircle.Position=center
        fovCircle.Visible=Aim.On and Aim.ShowFOV
    end

    if not Aim.On then
        if aimDot then aimDot.Visible=false end
        return
    end

    local cam=workspace.CurrentCamera
    local target=GetClosestTarget()
    Aim.Target=target

    if not target or not target.Parent then
        if aimDot then aimDot.Visible=false end
        -- Update label every ~30 frames
        return
    end

    local screenPos,onScreen=WorldToScreen(target.Position)

    -- Show aim dot on target
    if aimDot and onScreen then
        aimDot.Position=screenPos
        aimDot.Visible=true
    end

    -- Silent Aim — manipulate bullet via CFrame snap (tool-based)
    if Aim.SilentOn then
        pcall(function()
            local tool=LP.Character:FindFirstChildOfClass("Tool")
            if tool then
                local handle=tool:FindFirstChild("Handle")
                if handle then
                    -- Redirect aim silently
                    cam.CFrame=CFrame.lookAt(cam.CFrame.Position,target.Position)
                end
            end
        end)
        return
    end

    -- Normal Aimbot — smooth camera towards target
    local targetCF=CFrame.lookAt(cam.CFrame.Position,target.Position)
    cam.CFrame=cam.CFrame:Lerp(targetCF, math.clamp(Aim.Smoothing + dt*10, 0.01, 1))

    -- TriggerBot
    if Aim.TriggerBot then
        local dist=(screenPos-center).Magnitude
        if dist <= Aim.TriggerDist then
            pcall(function()
                -- Fire mouse click
                local vi=Instance.new("VirtualInputManager")
                vi:SendMouseButtonEvent(center.X,center.Y,0,true,game,0)
                task.delay(0.05,function()
                    pcall(function() vi:SendMouseButtonEvent(center.X,center.Y,0,false,game,0) end)
                end)
            end)
        end
    end
end))

