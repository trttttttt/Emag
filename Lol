local FBV,FBG
C(RunService.RenderStepped:Connect(function()
    if not S.FlyOn then
        if FBV then pcall(function() FBV:Destroy() end); FBV=nil end
        if FBG then pcall(function() FBG:Destroy() end); FBG=nil end; return
    end
    local hrp=GetHRP(); if not hrp then return end
    if not FBV or not FBV.Parent then
        FBV=Instance.new("BodyVelocity",hrp); FBV.MaxForce=Vector3.new(1e5,1e5,1e5); FBV.Velocity=Vector3.zero
        FBG=Instance.new("BodyGyro",hrp);     FBG.MaxTorque=Vector3.new(1e5,1e5,1e5); FBG.P=9000
    end
    local cam=workspace.CurrentCamera; local d=Vector3.zero
    if UIS:IsKeyDown(Enum.KeyCode.W)           then d=d+cam.CFrame.LookVector  end
    if UIS:IsKeyDown(Enum.KeyCode.S)           then d=d-cam.CFrame.LookVector  end
    if UIS:IsKeyDown(Enum.KeyCode.A)           then d=d-cam.CFrame.RightVector end
    if UIS:IsKeyDown(Enum.KeyCode.D)           then d=d+cam.CFrame.RightVector end
    if UIS:IsKeyDown(Enum.KeyCode.Space)       then d=d+Vector3.yAxis end
    if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then d=d-Vector3.yAxis end
    FBV.Velocity=d.Magnitude>0 and d.Unit*S.FlySpeed or Vector3.zero
    FBG.CFrame=cam.CFrame
end))

