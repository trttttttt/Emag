-- Helper: buat quest ID
local function makeQuestId(world, part)
    return world .. "_Main_Part_" .. tostring(part)
end

-- Helper: ambik QuestService
local function getQuestSvc()
    return ReplicatedStorage.Packages._Index
        :FindFirstChild("sleitnick_knit@1.5.1")
        .knit.Services.QuestService
end

-- Helper: ambik player data dari Replica
local function getRepData()
    local ok, d = pcall(function() return shared.Replica.Data end)
    return ok and d or nil
end

-- Helper: ambik Balance.Quests[questId]
local function getQuestBalance(questId)
    local ok, d = pcall(function()
        return ReplicatedStorage.Packages._Index
            :FindFirstChild("sleitnick_knit@1.5.1")
            .knit.Library.Balance.Quests[questId]
    end)
    return ok and d or nil
end

-- Accept quest Part ke-N
local function acceptQuestPart(part)
    local questId = makeQuestId(selectedWorld, part)
    pcall(function()
        getQuestSvc().RF.AcceptQuest:InvokeServer(questId)
    end)
end

-- Complete quest Part ke-N
local function completeQuestPart(part)
    local questId = makeQuestId(selectedWorld, part)
    pcall(function()
        getQuestSvc().RF.CompleteQuest:InvokeServer(questId)
    end)
end

-- Semak quest Part ke-N dah accepted (ada dalam player data)
local function isQuestAccepted(part)
    local data = getRepData()
    if not data or not data.Quests then return false end
    return data.Quests[makeQuestId(selectedWorld, part)] ~= nil
end

-- Semak quest Part ke-N semua goals dah lengkap
local function isQuestComplete(part)
    local data = getRepData()
    if not data or not data.Quests then return false end
    local questId = makeQuestId(selectedWorld, part)
    local questState = data.Quests[questId]
    if not questState then return false end
    local bal = getQuestBalance(questId)
    if not bal or not bal.Goals then return false end
    for mobName, required in pairs(bal.Goals) do
        local current = (questState.Currents and questState.Currents[mobName]) or 0
        if current < required then return false end
    end
    return true
end

-- Semak quest Part ke-N dah completed sepenuhnya (dalam Completed Quests)
local function isQuestDone(part)
    local data = getRepData()
    if not data then return false end
    local questId = makeQuestId(selectedWorld, part)
    return data["Completed Quests"] and data["Completed Quests"][questId] ~= nil
end

-- Ambik semua mob targets dari quest Part sekarang (mob yang masih perlu dibunuh)
local function getCurrentQuestTargets(part)
    local data = getRepData()
    if not data or not data.Quests then return {} end
    local questId = makeQuestId(selectedWorld, part)
    local questState = data.Quests[questId]
    if not questState then return {} end
    local bal = getQuestBalance(questId)
    if not bal or not bal.Goals then return {} end
    local targets = {}
    for mobName, required in pairs(bal.Goals) do
        local current = (questState.Currents and questState.Currents[mobName]) or 0
        if current < required then
            targets[mobName] = {current = current, required = required}
        end
    end
    return targets
end

-- Tunjuk progress quest sekarang dalam Rayfield notify
local function showQuestProgress(part)
    local data = getRepData()
    if not data or not data.Quests then return end
    local questId = makeQuestId(selectedWorld, part)
    local questState = data.Quests[questId]
    if not questState then return end
    local bal = getQuestBalance(questId)
    if not bal or not bal.Goals then return end

    local lines = {}
    for mobName, required in pairs(bal.Goals) do
        local current = (questState.Currents and questState.Currents[mobName]) or 0
        local left = required - current
        table.insert(lines, mobName .. ": " .. current .. "/" .. required .. " (" .. left .. " lagi)")
    end
    Rayfield:Notify({
        Title = selectedWorld .. " Part " .. part,
        Content = table.concat(lines, "
"),
        Duration = 5,
        Image = 4483362458,
    })
end

-- Cari nearest mob dari targets table
local function findNearestFromTargets(targets)
    local hrp = getHRP()
    if not hrp then return nil, nil end
    local folder = workspace:FindFirstChild("Mobs")
    if not folder then return nil, nil end
    local nearestMob, nearestHum, nearestDist = nil, nil, math.huge
    for _, mob in ipairs(folder:GetChildren()) do
        local ok, text = pcall(function()
            return mob.HumanoidRootPart.EnemyOverhead.Enemy.Text
        end)
        if ok and text and targets[text] then
            local hum = mob:FindFirstChildOfClass("Humanoid")
            local mobHRP = mob:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and mobHRP then
                local dist = (hrp.Position - mobHRP.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestMob = mob
                    nearestHum = hum
                end
            end
        end
    end
    return nearestMob, nearestHum
end

-- Kill satu mob, tunggu mati
local function killMob(mob, hum)
    local dead = false
    local c1, c2, c3
    local function markDead() dead = true end
    c1 = hum.Died:Connect(markDead)
    c2 = hum:GetPropertyChangedSignal("Health"):Connect(function()
        if hum.Health <= 0 then markDead() end
    end)
    c3 = mob.AncestryChanged:Connect(function(_, p)
        if not p then markDead() end
    end)
    while not dead do
        task.wait(0.05)
        if not questFarmActive then break end
    end
    pcall(function() c1:Disconnect() end)
    pcall(function() c2:Disconnect() end)
    pcall(function() c3:Disconnect() end)
end

local function stopQuestFarm()
    questFarmActive = false
    if questFarmThread then task.cancel(questFarmThread) questFarmThread = nil end
end

local function startQuestFarm()
    stopQuestFarm()
    questFarmActive = true
    currentQuestPart = 1  -- mula dari Part 1

    questFarmThread = task.spawn(function()
        Rayfield:Notify({
            Title = "Quest Farm Mula",
            Content = selectedWorld .. " Part 1 → 7",
            Duration = 4,
            Image = 4483362458,
        })

        while questFarmActive and currentQuestPart <= 7 do
            local part = currentQuestPart

            -- Kalau quest ni dah completed sepenuhnya, skip terus ke next
            if isQuestDone(part) then
                Rayfield:Notify({
                    Title = "Part " .. part .. " Dah Siap",
                    Content = "Skip ke Part " .. (part + 1),
                    Duration = 3,
                    Image = 4483362458,
                })
                currentQuestPart = currentQuestPart + 1
                task.wait(0.3)
                continue
            end

            -- Accept kalau belum accepted
            if not isQuestAccepted(part) then
                acceptQuestPart(part)
                task.wait(0.5)
                -- Retry semak accepted
                local retries = 0
                while not isQuestAccepted(part) and retries < 10 do
                    task.wait(0.3)
                    retries = retries + 1
                end
                if not isQuestAccepted(part) then
                    -- Tak berjaya accept, skip
                    Rayfield:Notify({
                        Title = "Gagal Accept Part " .. part,
                        Content = "Cuba Part seterusnya...",
                        Duration = 4,
                        Image = 4483362458,
                    })
                    currentQuestPart = currentQuestPart + 1
                    task.wait(0.3)
                    continue
                end
                Rayfield:Notify({
                    Title = "Quest Accepted: Part " .. part,
                    Content = selectedWorld,
                    Duration = 3,
                    Image = 4483362458,
                })
            end

            -- Quest accepted - semak sama ada dah complete goals
            if isQuestComplete(part) then
                completeQuestPart(part)
                task.wait(0.5)
                Rayfield:Notify({
                    Title = "Quest Part " .. part .. " SELESAI!",
                    Content = "Maju ke Part " .. (part + 1),
                    Duration = 4,
                    Image = 4483362458,
                })
                currentQuestPart = currentQuestPart + 1
                task.wait(0.3)
                continue
            end

            -- Tunjuk progress
            showQuestProgress(part)

            -- Farm mob untuk Part ini
            local killCount = 0
            while questFarmActive and currentQuestPart == part do
                -- Semak lagi kena ke
                if isQuestComplete(part) then
                    completeQuestPart(part)
                    task.wait(0.5)
                    Rayfield:Notify({
                        Title = "Quest Part " .. part .. " SELESAI! ✓",
                        Content = "Total bunuh: " .. killCount .. " mob | Maju ke Part " .. (part + 1),
                        Duration = 5,
                        Image = 4483362458,
                    })
                    currentQuestPart = currentQuestPart + 1
                    break
                end

                local targets = getCurrentQuestTargets(part)
                -- Takde targets tapi quest belum complete (data belum update), wait
                local count = 0
                for _ in pairs(targets) do count = count + 1 end
                if count == 0 then
                    task.wait(0.3)
                    continue
                end

                local mob, hum = findNearestFromTargets(targets)
                if mob and hum then
                    teleportToMob(mob)
                    killMob(mob, hum)
                    killCount = killCount + 1
                    task.wait(0.1)

                    -- Tunjuk progress setiap 5 kill
                    if killCount % 5 == 0 then
                        showQuestProgress(part)
                    end
                else
                    task.wait(0.3)
                end
            end
        end

        if currentQuestPart > 7 then
            Rayfield:Notify({
                Title = "Quest Farm Habis!",
                Content = selectedWorld .. " Part 1-7 semua selesai!",
                Duration = 7,
                Image = 4483362458,
            })
            questFarmActive = false
        end
    end)
end

