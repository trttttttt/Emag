local function setNoclip(state)
    noclipEnabled = state
    if not state and Character then
        for _, part in ipairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

local function flyTo(targetPos, activeCheck)
    if not HRP or not Humanoid then return false end
    Humanoid.PlatformStand = true
    setNoclip(true)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = Vector3.zero
    bv.Parent   = HRP
    activeBV    = bv
    local t0, reached = tick(), false
    while tick() - t0 < 60 do
        if activeCheck and not activeCheck() then break end
        if not HRP or not HRP.Parent or not bv.Parent then break end
        local dist = (targetPos - HRP.Position).Magnitude
        if dist <= 3 then reached = true; break end
        bv.Velocity = (targetPos - HRP.Position).Unit * (dist <= 15 and math.max(10, flySpeed * dist / 15) or flySpeed)
        task.wait()
    end
    if bv.Parent then bv.Velocity = Vector3.zero; task.wait(0.05); bv:Destroy() end
    activeBV = nil
    if reached and HRP and HRP.Parent then
        HRP.CFrame = CFrame.new(targetPos)
        HRP.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.05)
    end
    Humanoid.PlatformStand = false
    return reached
end

local function stopFlyNoclip()
    if activeBV and activeBV.Parent then activeBV.Velocity = Vector3.zero; activeBV:Destroy() end
    activeBV = nil
    if HRP then
        for _, bv in ipairs(HRP:GetChildren()) do
            if bv:IsA("BodyVelocity") then bv.Velocity = Vector3.zero; bv:Destroy() end
        end
        HRP.AssemblyLinearVelocity  = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero
        HRP.Anchored = true; task.wait(0.15); HRP.Anchored = false
        HRP.AssemblyLinearVelocity  = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero
    end
    setNoclip(false)
    if Humanoid then Humanoid.PlatformStand = false; Humanoid.AutoRotate = true end
    task.delay(0.2, function()
        if Humanoid then Humanoid.PlatformStand = false; Humanoid.AutoRotate = true end
        if HRP then HRP.AssemblyLinearVelocity = Vector3.zero; HRP.AssemblyAngularVelocity = Vector3.zero end
    end)
end

