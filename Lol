-- Aimbot loop (Camera+1 priority, player can still move)
local _trigCooldown=0
RunService:BindToRenderStep("NexusAimbot",Enum.RenderPriority.Camera.Value+1,function(dt)
    local center=GetCenter()
    pcall(function()
        if fovCircle then fovCircle.Position=center; fovCircle.Visible=Aim.On and Aim.ShowFOV end
    end)
    if not Aim.On then pcall(function() if aimDot then aimDot.Visible=false end end); return end
    local cam=workspace.CurrentCamera
    local target=GetTarget(); Aim.Target=target
    if not target or not target.Parent then pcall(function() if aimDot then aimDot.Visible=false end end); return end
    local sp,vis=W2S(target.Position)
    pcall(function() if aimDot then aimDot.Position=sp; aimDot.Visible=vis end end)
    if Aim.SilentOn then
        local oldCF=cam.CFrame
        cam.CFrame=CFrame.lookAt(cam.CFrame.Position,target.Position)
        task.defer(function() pcall(function() cam.CFrame=oldCF end) end)
    else
        local speed=(21-Aim.Smoothing)
        local lerpF=math.clamp(speed*dt*3,0.01,0.95)
        local targetCF=CFrame.lookAt(cam.CFrame.Position,target.Position)
        cam.CFrame=cam.CFrame:Lerp(targetCF,lerpF)
    end
    -- TriggerBot — throttled 250ms
    if Aim.TriggerBot then
        _trigCooldown=_trigCooldown-dt
        if _trigCooldown<=0 and (sp-center).Magnitude<=Aim.TriggerDist then
            _trigCooldown=0.25
            task.spawn(function()
                pcall(function()
                    if mouse1click then mouse1click()
                    else
                        local VU=game:GetService("VirtualUser")
                        VU:Button1Down(Vector2.new(0,0),cam.CFrame)
                        task.wait(0.08)
                        VU:Button1Up(Vector2.new(0,0),cam.CFrame)
                    end
                end)
            end)
        end
    end
end)
C(function() pcall(function() RunService:UnbindFromRenderStep("NexusAimbot") end) end)

