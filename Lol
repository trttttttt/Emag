local function GetViewportCenter()
    local vp=workspace.CurrentCamera.ViewportSize
    return Vector2.new(vp.X/2, vp.Y/2)
end

local function WorldToScreen(pos)
    local cam=workspace.CurrentCamera
    local screenPos,onScreen=cam:WorldToViewportPoint(pos)
    return Vector2.new(screenPos.X,screenPos.Y), onScreen, screenPos.Z
end

local function IsAlive(char)
    if not char then return false end
    local h=char:FindFirstChildOfClass("Humanoid")
    return h and h.Health>0
end

local function IsSameTeam(player)
    if not Aim.TeamCheck then return false end
    return LP.Team and player.Team==LP.Team
end

local function HasWall(from, to)
    if not Aim.WallCheck then return false end
    local ray=RaycastParams.new()
    ray.FilterDescendantsInstances={LP.Character,workspace.CurrentCamera}
    ray.FilterType=Enum.RaycastFilterType.Exclude
    local result=workspace:Raycast(from,(to-from).Unit*(to-from).Magnitude,ray)
    return result~=nil
end

local function GetClosestTarget()
    local cam=workspace.CurrentCamera
    local center=GetViewportCenter()
    local closest=nil
    local closestDist=math.huge

    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        if IsSameTeam(p) then continue end
        local char=p.Character; if not IsAlive(char) then continue end
        local part=char:FindFirstChild(Aim.HitPart) or char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end

        local screenPos,onScreen=WorldToScreen(part.Position)
        if not onScreen then continue end

        local dist=(screenPos-center).Magnitude
        if dist < Aim.FOV/2 and dist < closestDist then
            -- Wall check
            local hrp=GetHRP()
            if hrp and HasWall(hrp.Position,part.Position) then continue end
            closest=part
            closestDist=dist
        end
    end
    return closest
end

