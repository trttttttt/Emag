end

local function teleportToStar(starName)
    local hrp = getHRP()
    local ok, cube = pcall(function()
        return workspace.Stars[starName].Cube
    end)
    if hrp and ok and cube then
        hrp.CFrame = CFrame.new(cube.Position) * CFrame.new(5, 0, 0)
    end
end

local function isNearStar(starName)
    local hrp = getHRP()
    local ok, cube = pcall(function()
        return workspace.Stars[starName].Cube
    end)
    if hrp and ok and cube then
        return (hrp.Position - cube.Position).Magnitude <= 10
    end
    return false
end

local function teleportToMob(mob)
