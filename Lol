local GamemodeTab = Window:CreateTab("Gamemode", "gamepad-2")

local function findDungeonMob()
    local hrp = getHRP()
    if not hrp then return nil, nil end
    local bestMob, bestHum, bestDist = nil, nil, math.huge
    local function scanFolder(folder)
        if not folder then return end
        for _, mob in ipairs(folder:GetChildren()) do
            local hum = mob:FindFirstChildOfClass("Humanoid")
            local mobHRP = mob:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and mobHRP then
                local dist = (hrp.Position - mobHRP.Position).Magnitude
                if dist < bestDist then bestDist = dist bestMob = mob bestHum = hum end
            end
        end
    end
    scanFolder(workspace:FindFirstChild("Mobs"))
    local area = lp:GetAttribute("Area")
    if area then
        local maps = workspace:FindFirstChild("Maps")
        if maps then
            local af = maps:FindFirstChild(area)
            if af then scanFolder(af:FindFirstChild("Mobs")) scanFolder(af:FindFirstChild("Enemies")) end
        end
        local gm = ReplicatedStorage:FindFirstChild("Gamemodes")
        if gm then
            for _, gmf in ipairs(gm:GetChildren()) do
                local inst = gmf:FindFirstChild(area)
                if inst then scanFolder(inst:FindFirstChild("Mobs")) scanFolder(inst:FindFirstChild("Enemies")) end
            end
        end
    end
    return bestMob, bestHum
end

