-- TAB 3: EGG FARM
-- Kalau mob farm ON + egg ON: egg farm mobs bila gems tak cukup
-- Kalau egg ON sahaja: notify gems tak cukup, tak farm mob
-- =====================
local EggTab = Window:CreateTab("Egg", nil)
local selectedStar = nil
local selectedOpenAmount = 4
local eggActive = false
local eggThread = nil

local function getStarNames()
    local result = {}
    local seen = {}
    local folder = workspace:FindFirstChild("Stars")
    if not folder then return {"No Stars Found"} end
    for _, star in ipairs(folder:GetChildren()) do
        local name = star.Name
        if name and name ~= "" and not seen[name] then
            seen[name] = true
            table.insert(result, name)
        end
    end
    if #result == 0 then return {"No Stars Found"} end
    return result
end

local function stopEgg()
    eggActive = false
    if eggThread then task.cancel(eggThread) eggThread = nil end
end

local function startEgg()
    stopEgg()
    if not selectedStar or selectedStar == "No Stars Found" then return end
    eggActive = true

    eggThread = task.spawn(function()
        teleportToStar(selectedStar)
        task.wait(0.5)

        local notifyCooldown = 0

        while eggActive do
            -- Pastikan dekat star
            if not isNearStar(selectedStar) then
                teleportToStar(selectedStar)
                task.wait(0.3)
                continue
            end

            local cost = getEggCost(selectedStar)
            local totalCost = cost * selectedOpenAmount
            local currentGems = getPlayerGems()

            -- Gems cukup atau cost tak dapat baca = fire terus
            if cost == 0 or currentGems >= totalCost then
                pcall(function()
                    ReplicatedStorage.Packages._Index
                        :FindFirstChild("sleitnick_knit@1.5.1")
                        .knit.Services.StarService.RF.OpenStar
                        :InvokeServer(selectedStar, selectedOpenAmount)
                end)
                notifyCooldown = 0
                task.wait(0.1)
            else
                -- Gems tak cukup
                if farmActive and #selectedMobs > 0 then
                    -- Mob farm ON: pegi farm sampai cukup gems
                    Rayfield:Notify({
                        Title = "Farming Gems",
                        Content = "Need " .. tostring(totalCost) .. " | Have " .. tostring(currentGems),
                        Duration = 4,
                        Image = 4483362458,
                    })
                    -- Stop farm thread sementara, guna egg thread untuk farm
                    local wasFarmActive = farmActive
                    if farmThread then task.cancel(farmThread) farmThread = nil end

                    while eggActive do
                        local nowGems = getPlayerGems()
                        local nowCost = getEggCost(selectedStar) * selectedOpenAmount
                        if nowGems >= nowCost and nowCost > 0 then break end
                        doMobFarmCycle()
                    end

                    -- Restart mob farm thread kalau memang active
                    if wasFarmActive and farmActive then
                        startFarm()
                    end

                    -- Balik ke star
                    if eggActive then
                        teleportToStar(selectedStar)
                        task.wait(0.5)
                    end
                else
                    -- Mob farm OFF: notify je, jangan farm mob
                    notifyCooldown = notifyCooldown + 0.1
                    if notifyCooldown >= 10 then
                        Rayfield:Notify({
                            Title = "Gems Not Enough",
                            Content = "Need " .. tostring(totalCost) .. " | Have " .. tostring(currentGems),
                            Duration = 5,
                            Image = 4483362458,
                        })
                        notifyCooldown = 0
                    end
                    task.wait(0.1)
                end
            end
        end
    end)
end

