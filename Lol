local SecESP = TabVisual:CreateCollapsibleSection({Name="ESP", Icon="eye", DefaultOpen=true})

local espHighlights = {}
local function ClearESP()
    for _, h in pairs(espHighlights) do pcall(function() h:Destroy() end) end
    espHighlights = {}
end
local function BuildESP()
    ClearESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        pcall(function()
            local c = p.Character
            if not c then return end
            local h = Instance.new("Highlight", c)
            h.FillColor           = State.ESPColor
            h.OutlineColor        = Color3.new(1,1,1)
            h.FillTransparency    = 0.5
            h.OutlineTransparency = 0
            espHighlights[p.Name] = h
        end)
    end
end

SecESP:CreateToggle({
    Name="Player ESP", Flag="ESPOn", CurrentValue=false,
    Description="Highlight players through walls",
    Callback=function(v)
        State.ESPOn = v
        if v then BuildESP() else ClearESP() end
