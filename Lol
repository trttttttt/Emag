-- ===========================================================
-- Kill / Death Tracking
-- ===========================================================
local function TrackKD(char)
    local h=char:FindFirstChildOfClass("Humanoid"); if not h then return end
    h.Died:Connect(function()
        S.Deaths+=1; cDeaths:SetValue(tostring(S.Deaths))
        Notif("You Died","Deaths: "..S.Deaths,"error")
    end)
end
if LP.Character then pcall(function() TrackKD(LP.Character) end) end
C(LP.CharacterAdded:Connect(function(c) task.wait(1); pcall(function() TrackKD(c) end) end))

