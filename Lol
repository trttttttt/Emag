    local hrp=GetHRP(); if not hrp then return end
    local filter=(Nexus.Flags["CollectFilter"] or ""):lower()
    local range=Nexus.Flags["CollectRange"] or 30
    for _,obj in ipairs(workspace:GetDescendants()) do
