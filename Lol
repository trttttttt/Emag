-- Kill Aura loop
task.spawn(function()
    while task.wait(AuraDelay) do
        if not State.AuraOn then continue end
        local hrp = GetHRP()
        if not hrp then continue end
        for _, p in ipairs(Players:GetPlayers()) do
            if p == LP then continue end
            pcall(function()
                local c = p.Character
                if not c then return end
                local target = c:FindFirstChild(AuraHitPart) or c:FindFirstChild("HumanoidRootPart")
                local hum = c:FindFirstChildOfClass("Humanoid")
                if not target or not hum or hum.Health <= 0 then return end
                if (hrp.Position - target.Position).Magnitude <= State.AuraRange then
                    -- Simulate a tool hit via remote (game-specific, fallback: damage direct)
                    hum:TakeDamage(math.huge)
                end
            end)
            task.wait(0.01)
        end
    end
end)

