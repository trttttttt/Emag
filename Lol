        end

        local function SetState(v, silent)
            state = v
            Tween(Tr,{BackgroundColor3=v and Theme.ToggleOn or Theme.ToggleOff},0.2)
            Tween(Th,{Position=v and UDim2.new(1,-19,0.5,0) or UDim2.new(0,3,0.5,0)},0.2)
