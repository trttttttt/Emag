-- Handle format 165.73k, 1.2m, dll
local function parseNumber(val)
    local s = tostring(val):gsub(",", ""):lower()
    local num, suffix = s:match("^([%d%.]+)([kmb]?)$")
    if not num then return 0 end
    num = tonumber(num) or 0
    if suffix == "k" then num = num * 1000
    elseif suffix == "m" then num = num * 1000000
    elseif suffix == "b" then num = num * 1000000000 end
    return math.floor(num)
end

local function getPlayerGems()
    local ls = lp:FindFirstChild("leaderstats")
    if ls then
        local gems = ls:FindFirstChild("Gems")
        if gems then return parseNumber(gems.Value) end
    end
    return 0
end

local function getEggCost(starName)
