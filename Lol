local EggTab = Window:CreateTab("Egg", nil)
local selectedStar = nil
local selectedOpenAmount = 4
local eggThread = nil

local function getStarNames()
    local result, seen = {}, {}
    local folder = workspace:FindFirstChild("Stars")
    if not folder then return {"No Stars Found"} end
    for _, star in ipairs(folder:GetChildren()) do
        local name = star.Name
        if name and name ~= "" and not seen[name] then
            seen[name] = true
            table.insert(result, name)
        end
    end
    return #result > 0 and result or {"No Stars Found"}
end

local function _stopEggOnly()
    eggActive = false
    if eggThread then task.cancel(eggThread) eggThread = nil end
end

local function stopEgg()
    _stopEggOnly()
    if farmActive and #selectedMobs > 0 then
        startFarmThread()
    end
end

local function startEgg()
    _stopEggOnly()
    if not selectedStar or selectedStar == "No Stars Found" then return end
    if farmThread then task.cancel(farmThread) farmThread = nil end
    eggActive = true
    eggThread = task.spawn(function()
        teleportToStar(selectedStar)
        task.wait(0.5)
        local notifyCooldown = 0
        while eggActive do
            if not isNearStar(selectedStar) then
                teleportToStar(selectedStar)
                task.wait(0.3)
                continue
            end
            local cost = getEggCost(selectedStar)
            local totalCost = cost * selectedOpenAmount
            local currentGems = getPlayerGems()
            if cost == 0 or currentGems >= totalCost then
                pcall(function()
                    getService("StarService").RF.OpenStar:InvokeServer(selectedStar, selectedOpenAmount)
                end)
                notifyCooldown = 0
                task.wait(0.1)
            else
                if farmActive and #selectedMobs > 0 then
                    Rayfield:Notify({
                        Title = "Gems Tak Cukup — Farming Dulu",
                        Content = "Perlu: " .. totalCost .. " | Ada: " .. currentGems,
                        Duration = 4, Image = 4483362458
                    })
                    while eggActive do
                        local ng = getPlayerGems()
                        local nc = getEggCost(selectedStar) * selectedOpenAmount
                        if ng >= nc and nc > 0 then break end
                        local mob, hum = findNearestMob(selectedMobs)
                        if mob and hum then
                            teleportToMob(mob)
                            spamClickKill(mob, hum, function() return eggActive end)
                        else
                            task.wait(0.3)
                        end
                    end
                    if eggActive then
                        Rayfield:Notify({
                            Title = "Gems Cukup! Balik Egg",
                            Content = selectedStar .. " | " .. tostring(getPlayerGems()) .. " gems",
                            Duration = 3, Image = 4483362458
                        })
                        teleportToStar(selectedStar)
                        task.wait(0.5)
                    end
                else
                    notifyCooldown = notifyCooldown + 0.1
                    if notifyCooldown >= 10 then
                        Rayfield:Notify({
                            Title = "Gems Tak Cukup",
                            Content = "Perlu: " .. totalCost .. " | Ada: " .. currentGems,
                            Duration = 5, Image = 4483362458
                        })
                        notifyCooldown = 0
                    end
                    task.wait(0.1)
                end
            end
        end
    end)
end

