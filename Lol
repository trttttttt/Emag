local function Tween(obj, props, t, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or 0.22,
            style or Enum.EasingStyle.Quart,
            dir   or Enum.EasingDirection.Out
        ), props):Play()
end

local function New(class, props, children)
    local o = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then o[k] = v end
    end
    for _, c in pairs(children or {}) do c.Parent = o end
    if props and props.Parent then o.Parent = props.Parent end
    return o
end

local function MakeDraggable(frame, handle)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = input.Position
            startPos  = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

-- ════════════════════════════
--       CONFIG SAVE SYSTEM
-- ════════════════════════════
local ConfigSystem = {}
ConfigSystem.__index = ConfigSystem

function ConfigSystem.new(fileName, enabled)
    local self = setmetatable({}, ConfigSystem)
    self._file    = fileName or "nexui_config.json"
    self._enabled = enabled ~= false
    self._data    = {}
    self._callbacks = {} -- id -> set function
    if self._enabled then
        self:Load()
    end
    return self
end

function ConfigSystem:Load()
    if not self._enabled then return end
    local ok, raw = pcall(readfile, self._file)
    if ok and raw and raw ~= "" then
        local ok2, decoded = pcall(function()
            return HttpService:JSONDecode(raw)
        end)
        if ok2 and type(decoded) == "table" then
            self._data = decoded
        end
    end
end

function ConfigSystem:Save()
    if not self._enabled then return end
    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(self._data)
    end)
    if ok then
        pcall(writefile, self._file, encoded)
    end
end

function ConfigSystem:Set(id, value)
    self._data[id] = value
    self:Save()
end

function ConfigSystem:Get(id, default)
    local v = self._data[id]
    if v == nil then return default end
    return v
end

function ConfigSystem:Register(id, setFn)
    self._callbacks[id] = setFn
end

function ConfigSystem:ApplyAll()
    -- Apply loaded config to all registered elements
    for id, setFn in pairs(self._callbacks) do
        local val = self._data[id]
        if val ~= nil then
            pcall(setFn, val)
        end
    end
end

function ConfigSystem:Reset()
    self._data = {}
    self:Save()
    -- Reapply defaults by re-loading (data now empty, defaults kick in)
end

