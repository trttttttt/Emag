local T4 = Win:CreateTab("Visual","eye")

-- ESP
local sESP=T4:CreateCollapsibleSection({Name="ESP",Icon="eye",DefaultOpen=true})
local espH={}
local function ClearESP() for _,h in pairs(espH) do pcall(function() h:Destroy() end) end; espH={} end
local function BuildESP()
    ClearESP()
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        pcall(function()
            local c=p.Character; if not c then return end
            local h=Instance.new("Highlight",c)
            h.FillColor=S.ESPColor; h.OutlineColor=Color3.new(1,1,1)
            h.FillTransparency=0.5; h.OutlineTransparency=0
            espH[p.Name]=h
        end)
    end
end

sESP:CreateToggle({Name="Player ESP",Flag="ESPOn",CurrentValue=false,
    Description="Highlight players through walls",
    Callback=function(v) S.ESPOn=v; if v then BuildESP() else ClearESP() end end})
sESP:CreateColorPicker({Name="ESP Fill Color",Flag="ESPColor",Color=Color3.fromRGB(255,0,80),Callback=function(c)
    S.ESPColor=c; for _,h in pairs(espH) do h.FillColor=c end
end})
sESP:CreateToggle({Name="ESP Outline",Flag="ESPOutline",CurrentValue=true,Callback=function(v)
    for _,h in pairs(espH) do h.OutlineTransparency=v and 0 or 1 end
end})
sESP:CreateButton({Name="Refresh ESP",Icon="refresh",Callback=function()
    if S.ESPOn then BuildESP(); Notif("ESP","Refreshed.","success") end
end})

