GamemodeTab:CreateLabel("-- Boss Rush --")
local brFarmActive, brFarmThread = false, nil
local brAutoRejoinActive, brAutoRejoinThread = false, nil
local brLastArea = ""
local selectedBRVersion = "II"

-- Track area changes to detect kick/death (leaving BossRush area unexpectedly)
local brAreaConn = nil

local function brStopAutoRejoin()
    brAutoRejoinActive = false
    if brAutoRejoinThread then task.cancel(brAutoRejoinThread) brAutoRejoinThread = nil end
    if brAreaConn then brAreaConn:Disconnect() brAreaConn = nil end
end

local function brStartAutoRejoin()
    brStopAutoRejoin()
    brAutoRejoinActive = true

    -- Watch for when player gets kicked out of BossRush area
    brAreaConn = lp:GetAttributeChangedSignal("Area"):Connect(function()
        if not brAutoRejoinActive then return end
        local area = lp:GetAttribute("Area") or ""
        local wasInBR = brLastArea:find("BossRush")
        local nowInBR = area:find("BossRush")

        -- Player was in BossRush but got kicked/died out
        if wasInBR and not nowInBR then
            Rayfield:Notify({ Title = "Boss Rush", Content = "Kicked/Died — Rejoining...", Duration = 4, Image = 4483362458 })
            task.wait(2)
            if brAutoRejoinActive then
                pcall(function() getService("BossRushService").RF.Rejoin:InvokeServer() end)
                task.wait(1.5)
                -- If rejoin failed, try join fresh
                local newArea = lp:GetAttribute("Area") or ""
                if not newArea:find("BossRush") then
                    pcall(function() getService("BossRushService").RF.Join:InvokeServer(selectedBRVersion) end)
                end
            end
        end
        brLastArea = area
    end)

    -- Also poll every 5s as a backup in case AttributeChanged misses
    brAutoRejoinThread = task.spawn(function()
        while brAutoRejoinActive do
            local area = lp:GetAttribute("Area") or ""
            brLastArea = area
            task.wait(5)
        end
    end)

    brLastArea = lp:GetAttribute("Area") or ""
    Rayfield:Notify({ Title = "Boss Rush", Content = "Auto Rejoin ON — watching for kicks/deaths", Duration = 4, Image = 4483362458 })
end

