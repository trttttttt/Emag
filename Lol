            if not silent then pcall(cb, v) end
        end

        New("TextButton",{Parent=C,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=10}).MouseButton1Click:Connect(function()
            SetState(not state)
        end)
