local function refreshAlchLbls()
    if not selectedRecipe or not ALCHEMY_RECIPES[selectedRecipe] then return end
    local r = ALCHEMY_RECIPES[selectedRecipe]
    local herbUsed = {}
    for _, el in ipairs(r.Elements) do table.insert(herbUsed, getBestHerbForElement(el)) end
    alchLblHerbs:Set("Herbs: "..table.concat(herbUsed," | "))
    local total = calcRecipeBase(r, selectedAlchemyYear)
    alchLblBase:Set(total < r.Base
        and string.format("Base too low! Got ~%d, need %d", total, r.Base)
        or  string.format("Base OK: ~%d / %d required.", total, r.Base))
end

