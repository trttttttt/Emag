-- Aimbot
local Aim = {
    On=false, SilentOn=false, FOV=200, Smoothing=8,
    HitPart="Head", ShowFOV=true, TeamCheck=false, WallCheck=false,
    TriggerBot=false, TriggerDist=15, Target=nil,
}

local fovCircle = pcall(function() return Drawing end) and Drawing and Drawing.new("Circle") or nil
pcall(function()
    if not fovCircle then return end
    fovCircle.Visible=false; fovCircle.Radius=Aim.FOV; fovCircle.Thickness=1.5
    fovCircle.Color=Color3.fromRGB(0,224,255); fovCircle.Filled=false; fovCircle.NumSides=64
end)
local aimDot = pcall(function() return Drawing end) and Drawing and Drawing.new("Circle") or nil
pcall(function()
    if not aimDot then return end
    aimDot.Visible=false; aimDot.Radius=5; aimDot.Thickness=1
    aimDot.Color=Color3.fromRGB(255,50,50); aimDot.Filled=true; aimDot.NumSides=16
end)

local function GetCenter() local vp=workspace.CurrentCamera.ViewportSize; return Vector2.new(vp.X/2,vp.Y/2) end
local function W2S(pos) local sp,vis=workspace.CurrentCamera:WorldToViewportPoint(pos); return Vector2.new(sp.X,sp.Y),vis,sp.Z end
local function IsAlive(char) if not char then return false end; local h=char:FindFirstChildOfClass("Humanoid"); return h and h.Health>0 end

local function GetTarget()
    local center=GetCenter(); local best,bestDist=nil,math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        if Aim.TeamCheck and LP.Team and p.Team==LP.Team then continue end
        local char=p.Character; if not IsAlive(char) then continue end
        local part=char:FindFirstChild(Aim.HitPart) or char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        local sp,vis,depth=W2S(part.Position)
        if not vis or depth<0 then continue end
        local screenDist=(sp-center).Magnitude
        if screenDist>Aim.FOV then continue end
        if Aim.WallCheck then
            local hrp=GetHRP()
            if hrp then
                local rp=RaycastParams.new(); rp.FilterDescendantsInstances={LP.Character}; rp.FilterType=Enum.RaycastFilterType.Exclude
                local hit=workspace:Raycast(hrp.Position,(part.Position-hrp.Position),rp)
                if hit and hit.Instance and not char:IsAncestorOf(hit.Instance) then continue end
            end
        end
        if screenDist<bestDist then best=part; bestDist=screenDist end
    end
    return best
end

