local function runHarvestingCycle(progLbl)
    local activeName, activeProg, activePEnd = getActiveQuestOfType("Harvesting")
    if activeName and activeName ~= selectedHarvestingQuest then
        local aInfo = QUEST_DATA[activeName]
        if aInfo then
            progLbl:Set(activeProg .. " / " .. activePEnd)
            farmQuestHarvesting(activeName, aInfo.Target, progLbl)
        end
        if not harvestingActive then return end
    end
    if not selectedHarvestingQuest then return end
    local info = QUEST_DATA[selectedHarvestingQuest]
    if not info then return end
    local prog, pEnd = getProgressFromServer(selectedHarvestingQuest)
    if not prog then
        acceptQuest(selectedHarvestingQuest); task.wait(1)
        prog, pEnd = getProgressFromServer(selectedHarvestingQuest)
    end
    if not prog then return end
    if prog >= pEnd then return end
    progLbl:Set(prog .. " / " .. pEnd)
    farmQuestHarvesting(selectedHarvestingQuest, info.Target, progLbl)
end

