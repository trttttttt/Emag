local function doOneHerb()
    local list = type(selectedHerb)=="table" and selectedHerb or {selectedHerb}
    if not list or #list == 0 then return false end
    if herbRoundRobinIndex > #list then herbRoundRobinIndex = 1 end
    local tried = 0
    local foundHerb = nil
    while tried < #list do
        local herbName = list[herbRoundRobinIndex]
        herbRoundRobinIndex = (herbRoundRobinIndex % #list) + 1
        tried += 1
        local folder = getHerbFolder(herbName)
        if folder then
            local h = findRandomHerb(folder, 0, selectedHerbYear)
            if h then foundHerb = h; break end
        end
    end
    if not foundHerb or not foundHerb.Parent then return false end
    local zone = foundHerb:FindFirstChild("HerbZone", true)
    if not zone then return false end
    local targetCF = getCF(zone)
    if not targetCF then return false end
    -- Y+1.5 offset elak void fall
    local zonePos = targetCF.Position
    local safePos = Vector3.new(zonePos.X, zonePos.Y + 1.5, zonePos.Z)
    local reached = flyTo(safePos, function() return herbActive or treasureActive or altarActive end)
    if not (herbActive or treasureActive or altarActive) then return false end
    setNoclip(true)
    -- Kalau flyTo tak reach (herb dah terlalu dekat / sudah dekat), paksa warp ke zone
    if not reached then
        local zCF = getCF(zone)
        if zCF and HRP and HRP.Parent then
            HRP.CFrame = CFrame.new(zCF.Position.X, zCF.Position.Y + 1.5, zCF.Position.Z)
            HRP.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.1)
        end
    end
    local attempt = 0
    while not isPlayerInZone(zone) and attempt < 20 and (herbActive or treasureActive or altarActive) do
        attempt += 1
        local zCF = getCF(zone)
        if zCF then
            HRP.CFrame = CFrame.new(zCF.Position.X, zCF.Position.Y + 1.5, zCF.Position.Z)
            HRP.AssemblyLinearVelocity = Vector3.zero
        end
        task.wait(0.05)
    end
    if not isPlayerInZone(zone) then return false end
    task.wait(0.2)
    if not isPlayerInZone(zone) then return false end
    if HRP then HRP.Anchored = true end
    setNoclip(true)
    pcall(function() ReplicatedStorage.RemoteEvents.Harvest:FireServer() end)
    local result = waitForHarvestComplete(function() return herbActive or treasureActive or altarActive end)
    if HRP then
        HRP.Anchored = false
        HRP.AssemblyLinearVelocity = Vector3.zero
    end
    if result == "complete" then herbCollectCount += 1; return true end
    return false
end

