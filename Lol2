end)

local function setNoclip(state)
    noclipEnabled = state
    if not state and Character then
        for _, part in ipairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

local function flyTo(targetPos, activeCheck)
    if not HRP or not HRP.Parent or not Humanoid then return false end

    setNoclip(true)

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity  = Vector3.zero
    bv.Parent    = HRP
    activeBV     = bv

    local maxTime = 60
    local t0      = tick()
    local reached = false

    while tick() - t0 < maxTime do
        if activeCheck and not activeCheck() then break end
        if not HRP or not HRP.Parent then break end
        if not bv or not bv.Parent then reached = false; break end

        local currentPos = HRP.Position
        local dist       = (targetPos - currentPos).Magnitude

        if dist <= 3 then
            reached = true
            break
        end

        local dir = (targetPos - currentPos).Unit
        local speed
        if dist <= 15 then
            speed = math.max(10, flySpeed * (dist / 15))
        else
            speed = flySpeed
        end

        bv.Velocity = dir * speed
        task.wait()
    end

    if bv and bv.Parent then
        bv.Velocity = Vector3.zero
        task.wait(0.05)
        bv:Destroy()
    end
    activeBV = nil

    if reached and HRP and HRP.Parent then
        HRP.AssemblyLinearVelocity = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero
        -- Anchor tanpa snap CFrame — elak void fall kalau zone ada Y rendah
        HRP.Anchored = true
        task.wait(0.15)
        if HRP and HRP.Parent then
            HRP.Anchored = false
            HRP.AssemblyLinearVelocity = Vector3.zero
        end
    end

    return reached
end

local function stopFlyNoclip()
    if activeBV and activeBV.Parent then
        activeBV.Velocity = Vector3.zero
        activeBV:Destroy()
    end
    activeBV = nil

    if HRP then
        for _, bv in ipairs(HRP:GetChildren()) do
            if bv:IsA("BodyVelocity") then
                bv.Velocity = Vector3.zero
                bv:Destroy()
            end
        end
    end

    setNoclip(false)

    if Humanoid then
        Humanoid.PlatformStand = false
        Humanoid.AutoRotate    = true
    end

    if HRP and HRP.Parent then
        HRP.AssemblyLinearVelocity  = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero
        HRP.Anchored = true
        task.wait(0.15)
        if HRP and HRP.Parent then
            HRP.Anchored = false
            HRP.AssemblyLinearVelocity  = Vector3.zero
            HRP.AssemblyAngularVelocity = Vector3.zero
        end
    end

    task.spawn(function()
        local t0 = tick()
        while tick() - t0 < 0.6 do
            if Humanoid and Humanoid.Parent then
                Humanoid.PlatformStand = false
                Humanoid.AutoRotate    = true
            end
            if HRP and HRP.Parent then
                HRP.AssemblyLinearVelocity  = Vector3.zero
                HRP.AssemblyAngularVelocity = Vector3.zero
            end
            task.wait(0.05)
        end
        if Humanoid and Humanoid.Parent then
            pcall(function() Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end)
            task.wait(0.05)
            pcall(function() Humanoid:ChangeState(Enum.HumanoidStateType.Running) end)
        end
    end)
end

local function snapToGround()
    if not HRP or not HRP.Parent or not Character then return end

    setNoclip(false)
    if Humanoid then
        Humanoid.PlatformStand = false
        Humanoid.AutoRotate    = true
    end

    HRP.AssemblyLinearVelocity  = Vector3.zero
    HRP.AssemblyAngularVelocity = Vector3.zero
    HRP.Anchored = true

    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide = true end
    end
    task.wait(0.2)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {Character}
    params.FilterType = Enum.RaycastFilterType.Exclude

    local origin = HRP.Position + Vector3.new(0, 5, 0)
    local hit = workspace:Raycast(origin, Vector3.new(0, -500, 0), params)

    if hit then
        local groundY = hit.Position.Y + 3
        HRP.CFrame = CFrame.new(HRP.Position.X, groundY, HRP.Position.Z)
    else
        local safeY = 5
        pcall(function()
            local spawn = workspace:FindFirstChild("SpawnLocation")
            if spawn then safeY = spawn.Position.Y + 5 end
        end)
        HRP.CFrame = CFrame.new(HRP.Position.X, safeY, HRP.Position.Z)
    end

    HRP.AssemblyLinearVelocity  = Vector3.zero
    HRP.AssemblyAngularVelocity = Vector3.zero

    if Humanoid then
        Humanoid.PlatformStand = false
        Humanoid.AutoRotate    = true
    end

    task.wait(0.4)
    HRP.Anchored = false
    HRP.AssemblyLinearVelocity  = Vector3.zero
    HRP.AssemblyAngularVelocity = Vector3.zero

    task.wait(0.05)
    if Humanoid then
        pcall(function() Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.05)
        pcall(function() Humanoid:ChangeState(Enum.HumanoidStateType.Running) end)
    end
end

