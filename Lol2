local TabAuto = Window:CreateTab(" Auto", 4483362458)
TabAuto:CreateSection(" Auto Use Restoration Pill")

local autoPillEnabled       = false
local autoPillThread        = nil
local selectedAutoThreshold = "Low"
local autoPillSlot          = "IT. 1"

local AUTO_THRESHOLDS = {"Low", "Middle", "High", "Expert", "Master", "Peak"}

local function parseStatusProgress(text)
    local cur, max = text:match("(%d+)/(%d+)")
    if cur and max then return tonumber(cur), tonumber(max) end
    return nil, nil
end

local function usePill()
    local args = {
        [1] = "Use",
        [2] = 1,
        [3] = "Restoration Pill",
        [4] = selectedAutoThreshold,
        [5] = autoPillSlot,
    }
    pcall(function()
        game:GetService("ReplicatedStorage").RemoteFunctions.Item:InvokeServer(unpack(args))
    end)
    Rayfield:Notify({
        Title = "Auto Pill",
        Content = "Used Restoration Pill! (" .. selectedAutoThreshold .. ")",
        Duration = 4, Image = 4483362458
    })
end

-- Direct path from game source code
local function getStatusTextObj()
    return Player.PlayerGui:FindFirstChild("StatsGui")
        and Player.PlayerGui.StatsGui:FindFirstChild("StatusImageLabel")
        and Player.PlayerGui.StatsGui.StatusImageLabel:FindFirstChild("StatusText")
        or nil
end

local autoPillConnection = nil
local function runAutoPill()
    if autoPillConnection then autoPillConnection:Disconnect(); autoPillConnection = nil end
    local obj = getStatusTextObj()
    if not obj then
        Rayfield:Notify({Title="Auto Pill", Content="StatusText not found!", Duration=4, Image=4483362458})
        autoPillThread = nil
        return
    end
    local pillUsed = false
    -- Use .Changed event — instant, no polling
    autoPillConnection = obj:GetPropertyChangedSignal("Text"):Connect(function()
        if not autoPillEnabled then return end
        local text = obj.Text or ""
        local cur, max = parseStatusProgress(text)
        if cur and max and max > 0 then
            if cur >= max and not pillUsed then
                pillUsed = true
                usePill()
            elseif cur < max then
                pillUsed = false
            end
        end
    end)
    autoPillThread = nil
end

local autoLblStatus  = TabAuto:CreateLabel("Status: OFF")
local autoLblCurrent = TabAuto:CreateLabel("Progress: -")

TabAuto:CreateToggle({Name = "Auto Use Pill", CurrentValue = false,
    Callback = function(val)
        autoPillEnabled = val
        if val then
            autoLblStatus:Set("Status: ON")
            if autoPillThread then
                pcall(function() task.cancel(autoPillThread) end)
                autoPillThread = nil
            end
            autoPillThread = task.spawn(runAutoPill)
            task.spawn(function()
                local obj = getStatusTextObj()
                while autoPillEnabled do
                    if obj and obj.Parent then
                        autoLblCurrent:Set("Progress: " .. tostring(obj.Text))
                    else
                        obj = getStatusTextObj()
                        autoLblCurrent:Set("Progress: " .. (obj and tostring(obj.Text) or "not found"))
                    end
                    task.wait(0.1)
                end
                autoLblCurrent:Set("Progress: -")
            end)
            Rayfield:Notify({Title="Auto Pill", Content="Started! Grade: "..selectedAutoThreshold, Duration=3, Image=4483362458})
        else
            autoPillEnabled = false
            if autoPillThread then
                pcall(function() task.cancel(autoPillThread) end)
                autoPillThread = nil
            end
            if autoPillConnection then
                autoPillConnection:Disconnect()
                autoPillConnection = nil
            end
            autoLblStatus:Set("Status: OFF")
            autoLblCurrent:Set("Progress: -")
            Rayfield:Notify({Title="Auto Pill", Content="Stopped.", Duration=2, Image=4483362458})
        end
    end})

TabAuto:CreateDropdown({
    Name = "Grade", Options = AUTO_THRESHOLDS,
    CurrentOption = {"Low"}, MultipleOptions = false,
    Callback = function(opt)
        selectedAutoThreshold = opt[1]
        Rayfield:Notify({Title="Auto Pill", Content="Grade: "..selectedAutoThreshold, Duration=2, Image=4483362458})
    end})

TabAuto:CreateInput({
    Name = "Pill Slot (e.g. IT. 1)", CurrentValue = "IT. 1",
    PlaceholderText = "IT. 1",
    Callback = function(val) if val and val ~= "" then autoPillSlot = val end end})

TabAuto:CreateButton({Name = " Use Pill Now (Manual)", Callback = function()
    usePill()
end})

