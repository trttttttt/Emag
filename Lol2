-- ============================================================
-- MULTI-FARM COORDINATOR
-- ============================================================
local function runMultiFarm()
    setNoclip(true)
    local cycleIndex = 1
    while herbActive or treasureActive or altarActive do
        if justRespawned then
            while justRespawned and (herbActive or treasureActive or altarActive) do task.wait(0.5) end
            if not (herbActive or treasureActive or altarActive) then break end
            setNoclip(true)
        end
        if not HRP or not HRP.Parent then task.wait(0.5); continue end
        local queue = {}
        if altarActive    then table.insert(queue, {t="altar",    p=farmPriority.altar})    end
        if treasureActive then table.insert(queue, {t="treasure", p=farmPriority.treasure}) end
        if herbActive     then table.insert(queue, {t="herb",     p=farmPriority.herb})     end
        if #queue == 0 then break end
        table.sort(queue, function(a,b) return a.p < b.p end)
        if cycleIndex > #queue then cycleIndex = 1 end
        local tried = 0
        local didSomething = false
        while tried < #queue do
            local farm = queue[cycleIndex]
            cycleIndex = (cycleIndex % #queue) + 1
            tried += 1
            local ok = false
            if farm.t == "altar" and altarActive then
                setNoclip(true); ok = doOneAltar()
            elseif farm.t == "treasure" and treasureActive then
                setNoclip(true); ok = doOneTreasure()
            elseif farm.t == "herb" and herbActive then
                setNoclip(true); ok = doOneHerb()
            end
            if ok then
                didSomething = true
                task.wait(0.3)
                break
            end
        end
        if not didSomething then
            task.wait(2)
        end
    end
    multiFarmThread = nil
    if not (herbActive or treasureActive or altarActive) then
        stopFlyNoclip()
    end
end

local function ensureMultiFarmRunning()
    -- Only spawn new thread if old one truly died
    if multiFarmThread then
        local status = coroutine.status(multiFarmThread)
        if status == "suspended" or status == "running" or status == "normal" then
            return
        end
        multiFarmThread = nil
    end
    multiFarmThread = task.spawn(runMultiFarm)
end

